{
  "description": "Design Studio hooks — detect project context, validate HTML output, suggest follow-up commands",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/detect-design-context.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [],
    "Stop": []
  }
}
